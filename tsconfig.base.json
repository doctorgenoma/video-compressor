{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@workspace/ui": ["packages/ui/src/index.ts"],
      "@workspace/ui/*": ["packages/ui/src/*"],
      "@workspace/ffmpeg-client": ["packages/ffmpeg-client/src/index.ts"],
      "@workspace/ffmpeg-client/*": ["packages/ffmpeg-client/src/*"]
    }
  }
}